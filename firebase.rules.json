{
  "rules": {
    "matches": {
      ".read": true,
      "$matchId": {
        ".write": "auth != null"
      }
    },
    "tournaments": {
      ".read": true,
      "$tournId": {
        ".write": "auth != null"
      }
    },
    "football": {
      "matches": {
        ".read": true,
        "$matchId": {
          ".write": "auth != null"
        }
      },
      "tournaments": {
        ".read": true,
        "$tournId": {
          ".write": "auth != null"
        }
      }
    },
    "pickleball": {
      "matches": {
        ".read": true,
        "$matchId": {
          ".write": "auth != null"
        }
      },
      "tournaments": {
        ".read": true,
        "$tournId": {
          ".write": "auth != null"
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "usernames": {
      ".read": true,
      "$username": {
        ".write": "auth != null"
      }
    }
  }
}

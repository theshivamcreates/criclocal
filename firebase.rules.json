{
  "rules": {
    "matches": {
      ".read": true,
      "$matchId": {
        ".write": "auth != null && root.child('users/' + auth.uid + '/role').val() == 'admin'"
      }
    },
    "tournaments": {
      ".read": true,
      "$tournId": {
        ".write": "auth != null && root.child('users/' + auth.uid + '/role').val() == 'admin'"
      }
    },
    "football": {
      "matches": {
        ".read": true,
        "$matchId": {
          ".write": "auth != null && root.child('users/' + auth.uid + '/role').val() == 'admin'"
        }
      },
      "tournaments": {
        ".read": true,
        "$tournId": {
          ".write": "auth != null && root.child('users/' + auth.uid + '/role').val() == 'admin'"
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('users/' + auth.uid + '/role').val() == 'admin')",
        ".write": "auth != null && auth.uid == $uid && (!data.exists() || !newData.hasChild('role') || newData.child('role').val() == data.child('role').val())"
      }
    },
    "usernames": {
      ".read": true,
      "$username": {
        ".write": "auth != null"
      }
    }
  }
}

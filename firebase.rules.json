{
  "rules": {
    "matches": {
      ".read": true,
      "$matchId": {
        ".write": "auth != null && (data.child('meta/createdBy').val() === auth.uid || !data.exists())"
      }
    },
    "tournaments": {
      ".read": true,
      "$tournId": {
        ".write": "auth != null && (data.child('createdBy').val() === auth.uid || !data.exists())"
      }
    }
  }
}
